# Copie este arquivo para .env e preencha com sua chave
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — modelo usado pela Serena (default: claude-opus-4-7)
# SERENA_MODEL=claude-opus-4-7

# Opcional — modelo do judge (default: claude-opus-4-7)
# JUDGE_MODEL=claude-opus-4-7

# Opcional — paralelização (default: 5)
# SERENA_PARALLEL=5
# JUDGE_PARALLEL=5
