# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (Project Settings > Database > URI mode "Session") ──
DATABASE_URL=postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres

# ── Twilio (opcional — para notificações e envio de msgs) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...   # número Twilio WhatsApp Business

# ── Servidor ──────────────────────────────────────────
PORT=8000
