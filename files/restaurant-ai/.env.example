# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (Project Settings > Database > URI mode "Session") ──
DATABASE_URL=postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres

# ── Twilio (opcional — para notificações e envio de msgs) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...   # número Twilio WhatsApp Business

# ── Servidor ──────────────────────────────────────────
PORT=8000

# ── Agent Core Agnóstico ──────────────────────────────
AGENT_NAME=Serena
AGENT_IDENTITY_PROMPT=""  # Texto direto do prompt de identidade OU caminho para um arquivo .txt (ex: identity.txt)
BUSINESS_CONTEXT="Madonna Cucina, restaurante italiano premium em São Paulo"
WEBHOOK_SECRET=sua_webhook_secret_aqui

# ── Resend (emails transacionais) ─────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Serena <noreply@mdna.com.br>
RESEND_TEST_EMAIL=seu@email.com  # usado em dev quando domínio não propagou

